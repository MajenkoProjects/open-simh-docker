FROM debian:latest AS base

RUN apt-get update && apt-get install -y build-essential git tmux sysvinit-utils iproute2 bridge-utils bsdextrautils
RUN echo "Building SIMH." && \
	mkdir /work && \
	cd /work && \
	git clone --depth 1 https://github.com/open-simh/simh && \
	cd /work/simh && \
	make BIN/pdp11 && \
	cp BIN/pdp11 /bin && \
	rm -rf /work

COPY startup-sequence.pdp11 /etc/startup-sequence

HEALTHCHECK --interval=10s \
	CMD pidof -q /bin/pdp11

ENTRYPOINT ["/etc/startup-sequence"]
